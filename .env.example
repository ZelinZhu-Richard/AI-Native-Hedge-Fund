# Meridian Configuration
# Copy to .env and fill in values

# Database
MERIDIAN_DATABASE__PATH=data/meridian.duckdb
MERIDIAN_DATABASE__READ_ONLY=false

# Data Providers
MERIDIAN_DATA_PROVIDER__ALPHA_VANTAGE_API_KEY=
MERIDIAN_DATA_PROVIDER__YAHOO_RATE_LIMIT_PER_SECOND=2.0

# Ingestion
MERIDIAN_INGESTION__DEFAULT_BATCH_SIZE=50
MERIDIAN_INGESTION__MAX_RETRIES=3
MERIDIAN_INGESTION__RETRY_BASE_DELAY_SECONDS=1.0

# Logging
MERIDIAN_LOGGING__LEVEL=INFO
# Format: "pretty" for dev (colored console), "json" for prod
MERIDIAN_LOGGING__FORMAT=pretty
